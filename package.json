{
	"name": "bases-power-pack",
	"version": "1.1.0",
	"description": "Advanced database views and automation on top of Obsidian Bases — kanban, calendar, Gantt, roll-ups, formulas, and saved filters.",
	"main": "main.js",
	"type": "module",
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"build": "node esbuild.config.mjs production",
		"typecheck": "tsc -noEmit -skipLibCheck",
		"test": "node tests/engine.test.mjs && node tests/license.test.mjs",
		"license:generate": "node scripts/generate-license.mjs",
		"version": "node version-bump.mjs && git add manifest.json versions.json"
	},
	"keywords": [
		"obsidian",
		"plugin",
		"bases",
		"kanban",
		"calendar",
		"database"
	],
	"author": "iavil",
	"license": "MIT",
	"devDependencies": {
		"@types/node": "^24.0.0",
		"esbuild": "^0.28.1",
		"obsidian": "1.7.2",
		"typescript": "^5.8.3"
	},
	"dependencies": {
		"tweetnacl": "^1.0.3"
	}
}
